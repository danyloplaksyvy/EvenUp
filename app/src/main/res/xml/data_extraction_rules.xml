<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/evenup_auth_state.preferences_pb"/>
        <exclude domain="database" path="evenup_account_cache.db"/>
        <exclude domain="database" path="evenup_account_cache.db-shm"/>
        <exclude domain="database" path="evenup_account_cache.db-wal"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/evenup_auth_state.preferences_pb"/>
        <exclude domain="database" path="evenup_account_cache.db"/>
        <exclude domain="database" path="evenup_account_cache.db-shm"/>
        <exclude domain="database" path="evenup_account_cache.db-wal"/>
    </device-transfer>
</data-extraction-rules>
